{
  "name": "assetvault-extension",
  "version": "0.1.0",
  "private": true,
  "description": "AssetVault Pro browser extension — save web images via local Web API",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm exec vite build && node scripts/build-content.mjs && node scripts/postbuild.mjs",
    "package": "pnpm run build && node scripts/package.mjs",
    "package:crx": "pnpm run build && node scripts/package-crx.mjs",
    "clean": "node -e \"import('fs').then(fs=>{for(const p of ['dist','release']) fs.rmSync(p,{recursive:true,force:true})})\""
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "archiver": "^7.0.1",
    "crx3": "^1.1.3",
    "esbuild": "^0.24.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
