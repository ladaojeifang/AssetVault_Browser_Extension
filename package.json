{
  "name": "assetvault-extension",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "AssetVault Pro browser extension — save web images via local Web API",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test testing/unit/*.test.ts && node scripts/check-api-contract.mjs",
    "test:unit": "node --experimental-strip-types --test testing/unit/*.test.ts",
    "contract:sync": "node scripts/sync-api-contract.mjs",
    "contract:check": "node scripts/check-api-contract.mjs",
    "contract:gen": "openapi-typescript contracts/web-api-v1-openapi.yaml -o src/shared/api-contract.generated.ts",
    "contract": "pnpm run contract:sync && pnpm run contract:check",
    "smoke:pro": "node scripts/smoke-pro-api.mjs",
    "test:fullpage": "node --experimental-strip-types --test testing/unit/fullpage-long-capture.test.ts",
    "dev": "vite build --watch",
    "build": "pnpm run typecheck && pnpm exec vite build",
    "package": "pnpm run build && node scripts/package.mjs",
    "package:crx": "pnpm run build && node scripts/package-crx.mjs",
    "clean": "node -e \"import('fs').then(fs=>{for(const p of ['dist','release']) fs.rmSync(p,{recursive:true,force:true})})\""
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/dompurify": "^3.2.0",
    "@types/mozilla-readability": "^0.2.1",
    "@types/turndown": "^5.0.6",
    "archiver": "^7.0.1",
    "crx3": "^1.1.3",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "@joplin/turndown": "^4.0.85",
    "@joplin/turndown-plugin-gfm": "^1.0.67",
    "@mozilla/readability": "^0.6.0",
    "dompurify": "^3.4.7"
  }
}
